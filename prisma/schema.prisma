generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  description String?
  thumbnail   String?
  icon        String?
  tags        String[]
  category    String   @default("technical")
  type        String   @default("post")
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  series      String?
  seriesOrder Int?     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text

  // Image
  image       String?

  // Links
  demoUrl     String?
  repo        String?
  articleUrl  String?

  // GitHub data (auto-fetched)
  githubStars     Int?
  githubForks     Int?
  githubCreatedAt DateTime?
  githubUpdatedAt DateTime?
  githubLanguage  String?
  githubSyncedAt  DateTime?

  // Metadata
  tech        String[]
  year        Int?
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
  @@index([featured])
}

model Skill {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  icon      String?
  url       String?
  category   String   @default("language")
  level      String   @default("intermediate")
  yearsOfExp Float?
  sortOrder  Int      @default(0)
  featured   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([sortOrder])
  @@index([featured])
}

model Experience {
  id          String   @id @default(cuid())
  title       String
  company     String
  companyLogo String?
  location    String?
  startDate   DateTime
  endDate     DateTime?
  current     Boolean  @default(false)
  description String?  @db.Text
  tech        String[]
  projects    Json[]
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
  @@index([current])
}

model PageView {
  id          String   @id @default(cuid())
  path        String
  ipHash      String
  country     String   @default("Unknown")
  countryCode String   @default("XX")
  referrer    String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([ipHash, createdAt])
  @@index([country])
  @@index([path])
}

model SiteSettings {
  id         String   @id @default("main")
  name       String   @default("Bagas")
  siteName   String   @default("bagas.dev")
  tagline    String   @default("Software developer and open-source enthusiast")
  heroIntro  String   @db.Text @default("I'm a software developer and open-source enthusiast from Indonesia. I build modern web apps and write about development on this blog.")
  heroStyle  String   @default("playful")
  heroImage  String?
  heroRealisticImage String?
  heroRealisticPills String   @default("Next.js,TypeScript,React,Node.js")
  heroRealisticStat  String   @default("3+ Years")
  heroRealisticStatLabel String @default("in Software Development Experience")
  heroRealisticQuote String   @db.Text @default("")
  cvUrl      String   @default("")
  bio        String   @db.Text
  sidebarBio String   @default("I'm Bagas, software developer and open-source enthusiast from Indonesia. This is my corner of the universe. 🚀")
  github     String   @default("")
  linkedin   String   @default("")
  twitter    String   @default("")
  email      String   @default("")
  bluesky    String   @default("")
  rssEnabled Boolean  @default(true)
  // Homepage section visibility & ordering
  showExperience  Boolean @default(true)
  showBlog        Boolean @default(true)
  showNotes       Boolean @default(true)
  showSkills      Boolean @default(true)
  showProjects    Boolean @default(true)
  orderExperience Int     @default(0)
  orderBlog       Int     @default(1)
  orderNotes      Int     @default(2)
  orderSkills     Int     @default(3)
  orderProjects   Int     @default(4)
  // Sidebar navigation visibility & ordering
  navExperience   Boolean @default(true)
  navBlog         Boolean @default(true)
  navNotes        Boolean @default(true)
  navSkills       Boolean @default(true)
  navProjects     Boolean @default(true)
  navAbout        Boolean @default(true)
  navOrderExperience Int  @default(0)
  navOrderBlog       Int  @default(1)
  navOrderNotes      Int  @default(2)
  navOrderSkills     Int  @default(3)
  navOrderProjects   Int  @default(4)
  navOrderAbout      Int  @default(5)
  updatedAt  DateTime @updatedAt
}

model MascotSettings {
  id              String   @id @default("main")
  mascotType      String   @default("clawd")
  displayName     String   @default("Claw'd")
  greeting        String   @default("Hey! I'm Claw'd. What's up?")
  systemPrompt    String   @db.Text @default("You are Claw'd, a cheerful pixel crab assistant. You help the commander manage their site with enthusiasm and crab puns.")
  // OpenClaw integration
  gatewayUrl      String   @default("http://localhost:18789")
  authToken       String   @default("")
  agentId         String   @default("main")
  // Animation weights (percentages, must sum to 100)
  weightIdle      Int      @default(10)
  weightWalking   Int      @default(18)
  weightCoding    Int      @default(20)
  weightWriting   Int      @default(12)
  weightKarate    Int      @default(12)
  weightPhone     Int      @default(10)
  weightPresenting Int     @default(6)
  weightCoffee    Int      @default(6)
  weightCalling   Int      @default(6)
  // Appearance
  scale           Float    @default(1.0)
  moveSpeed       String   @default("normal")
  primaryColor    String   @default("#e8735a")
  showOn          String[] @default(["dashboard", "all"])
  background      String   @default("office")
  updatedAt       DateTime @updatedAt
}
