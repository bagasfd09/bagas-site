# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bagas_portfolio"

# Admin credentials
ADMIN_PASSWORD="your-secure-password"

# JWT secret (min 32 characters)
JWT_SECRET="your-jwt-secret-at-least-32-chars"

# Site URL (used for sitemap, OG tags, canonical URLs)
NEXT_PUBLIC_SITE_URL="https://bagas.dev"

# Google Search Console (optional - SEO analytics)
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_KEY=""
GOOGLE_SEARCH_CONSOLE_SITE="sc-domain:yourdomain.com"

# Google site verification (optional)
GOOGLE_SITE_VERIFICATION=""

# GitHub token (optional - for project sync, 5000 req/hr vs 60/hr)
GITHUB_TOKEN=""
